rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function friendshipExists(firstUid, secondUid) {
      return exists(/databases/$(database)/documents/friendships/$(firstUid + '_' + secondUid))
          || exists(/databases/$(database)/documents/friendships/$(secondUid + '_' + firstUid));
    }

    function sharingEnabled(uid) {
      return get(/databases/$(database)/documents/locationSharing/$(uid)).data.enabled == true
          && get(/databases/$(database)/documents/locationSharing/$(uid)).data.audience == 'friends';
    }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      match /savedGuides/{guideId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /publicProfiles/{uid} {
      allow read: if signedIn();
      allow create: if isOwner(uid)
          && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(uid)
          && request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(uid);
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn()
          && (request.auth.uid == resource.data.senderId
              || request.auth.uid == resource.data.receiverId);
      allow create: if signedIn()
          && requestId == request.auth.uid + '_' + request.resource.data.receiverId
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.receiverId != request.auth.uid
          && request.resource.data.status == 'pending';
      allow update: if signedIn()
          && request.auth.uid == resource.data.receiverId
          && resource.data.status == 'pending'
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.receiverId == resource.data.receiverId
          && request.resource.data.status in ['accepted', 'declined']
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'respondedAt']);
      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if signedIn() && request.auth.uid in resource.data.userIds;
      allow create: if signedIn()
          && request.auth.uid == getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.requestId)).data.receiverId
          && request.resource.data.userIds.size() == 2
          && getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.requestId)).data.status == 'accepted'
          && getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.requestId)).data.senderId in request.resource.data.userIds
          && getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.requestId)).data.receiverId in request.resource.data.userIds
          && (friendshipId == getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.requestId)).data.senderId + '_' + getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.requestId)).data.receiverId
              || friendshipId == getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.requestId)).data.receiverId + '_' + getAfter(/databases/$(database)/documents/friendRequests/$(request.resource.data.requestId)).data.senderId);
      allow update: if false;
      allow delete: if signedIn() && request.auth.uid in resource.data.userIds;
    }

    match /locationSharing/{uid} {
      allow read: if isOwner(uid)
          || (signedIn() && friendshipExists(request.auth.uid, uid));
      allow delete: if isOwner(uid);
      allow create, update: if isOwner(uid)
          && request.resource.data.audience == 'friends';
    }

    match /locations/{uid} {
      allow create, update: if isOwner(uid)
          && request.resource.data.ownerId == request.auth.uid
          && request.resource.data.expiresAt > request.time
          && request.resource.data.expiresAt <= request.time + duration.value(10, 'm');
      allow read: if isOwner(uid)
          || (signedIn()
              && friendshipExists(request.auth.uid, uid)
              && sharingEnabled(uid)
              && resource.data.expiresAt > request.time);
      allow delete: if isOwner(uid);
    }

    match /places/{placeId} {
      allow read: if signedIn() && resource.data.isPublished == true;
      allow write: if false;
    }

    match /guides/{guideId} {
      allow read: if signedIn() && resource.data.isPublished == true;
      allow write: if false;

      match /stops/{stopId} {
        allow read: if signedIn()
            && get(/databases/$(database)/documents/guides/$(guideId)).data.isPublished == true;
        allow write: if false;
      }
    }
  }
}
