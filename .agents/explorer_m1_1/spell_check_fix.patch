+      if (entry['en'] != null) addWordsFromText(entry['en']!);
+    }
+
+    // 4. Proper Nouns
+    const properNouns = {
+      'vietnam', 'việt nam', 'english', 'vietnamese', 'tiếng anh', 'tiếng việt',
+      'hanoi', 'hà nội', 'ho chi minh', 'hồ chí minh', 'saigon', 'sài gòn',
