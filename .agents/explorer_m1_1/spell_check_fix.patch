+      'beijing', 'singapore', 'thailand', 'thái lan', 'japan', 'nhật bản',
+      'korea', 'hàn quốc', 'america', 'mỹ', 'usa', 'uk', 'france', 'pháp',
+      'china', 'trung quốc', 'vn123', 'i', 'nhật', 'hàn', 'nga', 'đức'
+    };
+    for (final pn in properNouns) {
+      addWordsFromText(pn);
+    }
+
+    _knownWords = words;
+    return _knownWords!;
+  }
